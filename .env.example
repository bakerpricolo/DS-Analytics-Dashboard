# Copy to .env.local and fill in from your Supabase project settings → API

# Public (safe in browser) — used for dashboard reads
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NEVER commit, never ship to browser) — used by the seed script + future cron
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Later, for the live-pull cron:
CRON_SECRET=make-up-a-long-random-string
